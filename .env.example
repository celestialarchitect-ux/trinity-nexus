# Trinity Nexus configuration — copy to .env (the installer does this)

# =============================================================
# LOCAL MODELS (default — $0 per call, fully unrestricted)
# =============================================================
ORACLE_PRIMARY_MODEL=qwen3:4b
ORACLE_FAST_MODEL=qwen3:4b
ORACLE_EMBED_MODEL=bge-m3
ORACLE_OLLAMA_HOST=http://localhost:11434
ORACLE_NUM_CTX=16384
ORACLE_LLM_TIMEOUT_SEC=600
ORACLE_EMBED_KEEPALIVE=5m       # "0s" = unload after each call (tight VRAM)

# Inference backend:
#   ollama    — default; runs via Ollama daemon
#   llama_cpp — direct llama-cpp-python; parallel, KV-cache reuse (pip install)
NEXUS_BACKEND=ollama


# =============================================================
# FRONTIER MODELS (optional — hosted APIs, consulted as tools)
# =============================================================
# Nexus stays local-first. Frontier is on-demand via `frontier_ask` tool,
# `/frontier` REPL command, or as the distillation teacher.
#
# One OpenAI-compatible backend works for all these. Pick a provider:
#
#   openrouter — one key, access EVERYTHING (Claude, GPT, Gemini, Grok,
#                DeepSeek, Llama, Qwen, Mistral). Get key at openrouter.ai
#   anthropic  — Claude Opus 4.7 / Sonnet 4.6 / Haiku 4.5 direct
#                (use OpenRouter if you want native tool-calls and 1M ctx
#                 without two integrations)
#   openai     — GPT-5, o3, o4-mini. platform.openai.com
#   deepseek   — V3 cheap ($0.14/1M), R1 for reasoning. deepseek.com
#   groq       — Llama 3.3 70B at 1000+ tok/sec. groq.com
#   xai        — Grok 4. x.ai/api
#   mistral    — Large, Codestral. mistral.ai
#   together   — wide selection. together.ai
#   fireworks  — wide selection. fireworks.ai

NEXUS_FRONTIER_PROVIDER=openrouter
NEXUS_FRONTIER_API_KEY=
# Override any preset:
# NEXUS_FRONTIER_BASE_URL=https://openrouter.ai/api/v1
# NEXUS_FRONTIER_MODEL=anthropic/claude-opus-4-7


# =============================================================
# NIGHTLY DISTILLATION TEACHER
# =============================================================
# Options: local (free, weak) | deepseek (cheap, strong) | anthropic (best)
ORACLE_TEACHER_PROVIDER=local
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=


# =============================================================
# STORAGE (leave empty to use <repo>/data and <repo>/logs)
# =============================================================
# ORACLE_HOME=
# ORACLE_LOG_DIR=


# =============================================================
# IDENTITY
# =============================================================
ORACLE_DEVICE_NAME=nexus
ORACLE_USER=user
ORACLE_INSTANCE=Nexus


# =============================================================
# FEATURE FLAGS
# =============================================================
ORACLE_ENABLE_MESH=false
ORACLE_ENABLE_DISTILLATION=true
ORACLE_SANDBOX_PROVIDER=docker

# Banner: pixel | shadow | off
NEXUS_BANNER=pixel

# Session transcript recording (1 = on, 0 = off)
# Session logs auto-redact API keys / bearer tokens / PEM blocks.
NEXUS_RECORD=1

# ---------- Security (§29) ----------
# NEXUS_SAFE=1       hard lockdown: no run_command; writes restricted
# NEXUS_READONLY=1   total read-only — zero mutation tools
# NEXUS_WRITE_ALLOW  colon-separated globs where write is permitted in safe mode
#                    e.g.  C:/Users/Zach/Desktop/scratch/**:C:/Users/Zach/Downloads/**
NEXUS_SAFE=0
NEXUS_READONLY=0
NEXUS_WRITE_ALLOW=

# Destructive-op pattern gate for run_command (rm -rf, DROP TABLE, etc.)
# 1 = dangerous ops unlocked; prefer /dangerous in the REPL
NEXUS_ALLOW_DANGEROUS=0

# Rate limits (per minute, sliding window)
NEXUS_RATE_TOOLS_PER_MIN=120
NEXUS_RATE_LLM_PER_MIN=40

# Hook scripts in ~/.nexus/hooks/ (set "off" to disable)
NEXUS_HOOKS=
