# Oracle configuration — copy to .env (the installer does this for you)

# ---------- Models ----------
ORACLE_PRIMARY_MODEL=qwen3:4b
ORACLE_FAST_MODEL=qwen3:4b
ORACLE_EMBED_MODEL=bge-m3
ORACLE_OLLAMA_HOST=http://localhost:11434
ORACLE_NUM_CTX=2048
ORACLE_LLM_TIMEOUT_SEC=600

# Embedder keep_alive — "0s" unloads after every embed (free VRAM for a big
# primary model). "5m" keeps it hot between calls (faster, needs spare VRAM).
ORACLE_EMBED_KEEPALIVE=5m

# ---------- Teacher for nightly distillation ----------
# local    → use the primary model (no API keys needed, cheaper-to-beat gate)
# deepseek → https://api.deepseek.com  (~$0.14/1M tokens)
# anthropic → Claude as teacher (highest quality, highest $)
ORACLE_TEACHER_PROVIDER=local
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ---------- Storage ----------
# Leave empty to use <repo>/data and <repo>/logs (the installer default).
# Override to put Oracle's memory/retrieval elsewhere (e.g. a synced folder).
# ORACLE_HOME=
# ORACLE_LOG_DIR=

# ---------- Identity ----------
ORACLE_DEVICE_NAME=oracle
ORACLE_USER=user

# ---------- Feature flags ----------
ORACLE_ENABLE_MESH=false
ORACLE_ENABLE_DISTILLATION=true
ORACLE_SANDBOX_PROVIDER=docker      # docker | e2b | none

# ---------- Banner ----------
# pixel  (default) — thick 8-bit blocks, works in any monospace font
# shadow — thinner, uses box-drawing characters (needs a modern terminal font)
# off    — no banner
ORACLE_BANNER=pixel
